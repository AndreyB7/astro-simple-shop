---
const { videoId, title } = Astro.props;
---

<div class="flex justify-center" data-aos="fade-up">
  <div class="w-full md:w-3/4">
    <iframe
      class="w-full aspect-video rounded-xl border-0"
      src={`https://m.dzen.ru/embed/${videoId}?from_block=partner&from=zen&mute=0&autoplay=0&tv=0`}
      style="border: none;"
      title={title}
      allow="clipboard-write; autoplay; fullscreen"></iframe>
  </div>
</div>

